{
  "title": "review-api",
  "tags": ["nodejs", "api", "Platform Engineering"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "panels": [
    {
      "type": "stat",
      "title": "Availability",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "avg(up{job=\"review-api\"})"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Request Rate",
      "gridPos": { "x": 6, "y": 0, "w": 9, "h": 6 },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{service=\"review-api\"}[5m]))"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "CPU Usage",
      "gridPos": { "x": 0, "y": 6, "w": 9, "h": 6 },
      "targets": [
        {
          "expr": "sum(rate(container_cpu_usage_seconds_total{pod=~\"review-api.*\"}[5m]))"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Memory Usage",
      "gridPos": { "x": 9, "y": 6, "w": 9, "h": 6 },
      "targets": [
        {
          "expr": "sum(container_memory_working_set_bytes{pod=~\"review-api.*\"})"
        }
      ]
    }
  ]
}
